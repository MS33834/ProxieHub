# Example environment file for local development
# Copy this to .env and fill in real values only when needed.
# DO NOT commit .env to version control.

# GitHub personal access token (only needed for pushes from local machine)
# GH_TOKEN=ghp_xxx

# GitCode personal access token (only needed for pushes from local machine)
# GITCODE_TOKEN=xxx

# Pipeline tuning
# PROXIEHUB_VERIFY_NODES=false
# PROXIEHUB_MAX_NODES=500
# PROXIEHUB_MAX_PROXIES=200
# PROXIEHUB_CRAWL_WORKERS=8

# Frontend repository configuration (optional, defaults shown below)
# PROXIEHUB_GITHUB_OWNER=MS33834
# PROXIEHUB_REPO_NAME=ProxieHub
# PROXIEHUB_GITCODE_OWNER=badhope
