# ProxieHub backend environment configuration.
# Copy to .env and adjust. Never commit the real .env file.

# Application
PROXIEHUB_DEBUG=false
PROXIEHUB_API_PREFIX=/api
# Comma-separated CORS origins (empty = same-origin only via reverse proxy)
PROXIEHUB_CORS_ORIGINS=

# Database (SQLite by default; switch to postgresql+asyncpg for production)
PROXIEHUB_DATABASE_URL=sqlite:///data/proxiehub.db

# Admin API key for /api/admin/* endpoints. Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
PROXIEHUB_ADMIN_API_KEY=

# Pipeline tuning
PROXIEHUB_MAX_NODES=800
PROXIEHUB_MAX_PROXIES=300
PROXIEHUB_VERIFY_NODES=true
PROXIEHUB_VERIFY_TIMEOUT=5
PROXIEHUB_VERIFY_WORKERS=50
PROXIEHUB_GEO_ENABLED=false
PROXIEHUB_CRAWL_WORKERS=16

# Scheduler (cron expressions, empty = disabled)
PROXIEHUB_SCHEDULE_FULL_REFRESH=0 3 * * *
PROXIEHUB_SCHEDULE_VERIFY_ALIVE=*/30 * * * *
PROXIEHUB_SCHEDULE_VERIFY_DEAD=0 */6 * * *

# Paths (defaults point to project root)
# PROXIEHUB_SOURCES_CONFIG_PATH=/app/config/sources.json
# PROXIEHUB_NODES_OUTPUT_DIR=/app/nodes
